<view class="page">
  <view class="hero">
    <view class="hero-title">资产记录</view>
    <view class="hero-subtitle">按基金或账户维度更新成本、市值和标签，先把账记清楚。</view>
    <view class="status-bar">
      <view class="status-pill">{{cloudStatus.enabled ? '云端同步中' : '本地存储中'}}</view>
      <view class="status-pill" wx:if="{{cloudStatus.enabled}}">支持净值查询</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">{{editingId ? '编辑记录' : '新增记录'}}</view>
    <view class="form-card">
      <view class="field">
        <text class="field-label">基金名称</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="例如：中欧医疗健康" data-field="name" value="{{form.name}}" bindinput="handleInput" />
      </view>
      <view class="field">
        <text class="field-label">基金代码</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="可选" data-field="code" value="{{form.code}}" bindinput="handleInput" />
        <view class="button-row">
          <button class="button button-small" bindtap="fetchQuote">查询净值</button>
          <button class="button button-secondary button-small" bindtap="computeMarketValue">按净值算市值</button>
        </view>
        <view class="helper" wx:if="{{quoteStatus}}">{{quoteStatus}}</view>
      </view>
      <view class="field">
        <text class="field-label">总成本</text>
        <input class="input" placeholder-class="input-placeholder" type="digit" placeholder="例如：12000" data-field="cost" value="{{form.cost}}" bindinput="handleInput" />
      </view>
      <view class="field">
        <text class="field-label">持有份额</text>
        <input class="input" placeholder-class="input-placeholder" type="digit" placeholder="例如：10000.00" data-field="units" value="{{form.units}}" bindinput="handleInput" />
      </view>
      <view class="field">
        <text class="field-label">最新净值</text>
        <input class="input" placeholder-class="input-placeholder" type="digit" placeholder="查询后自动填充，也可手填" data-field="nav" value="{{form.nav}}" bindinput="handleInput" />
      </view>
      <view class="field">
        <text class="field-label">净值日期</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="YYYY-MM-DD" data-field="navDate" value="{{form.navDate}}" bindinput="handleInput" />
      </view>
      <view class="field">
        <text class="field-label">当前市值</text>
        <input class="input" placeholder-class="input-placeholder" type="digit" placeholder="例如：12650" data-field="marketValue" value="{{form.marketValue}}" bindinput="handleInput" />
      </view>
      <view class="field">
        <text class="field-label">记录日期</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="YYYY-MM-DD" data-field="date" value="{{form.date}}" bindinput="handleInput" />
      </view>
      <view class="field">
        <text class="field-label">标签</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="医药, 定投, 长期" data-field="tags" value="{{form.tags}}" bindinput="handleInput" />
      </view>
      <button class="button" bindtap="submitAsset">{{submitLabel}}</button>
      <button class="button button-secondary" wx:if="{{editingId}}" bindtap="resetForm">取消编辑</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">筛选与持仓汇总</view>
    <view class="form-card">
      <view class="field" style="margin-bottom: 0;">
        <text class="field-label">搜索</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="按基金名、代码、标签搜索" value="{{keyword}}" bindinput="handleKeywordInput" />
      </view>
    </view>
    <view class="section-title" style="margin-top: 24rpx;">按基金聚合</view>
    <block wx:if="{{assetGroups.length}}">
      <view class="card" wx:for="{{assetGroups}}" wx:key="key">
        <view class="row">
          <view class="strong">{{item.name}}</view>
          <view class="{{item.pnlClass}}">¥{{item.pnl}}</view>
        </view>
        <view class="muted">{{item.code || '未填代码'}} · {{item.positions}} 条记录 · 最新 {{item.latestDate}}</view>
        <view class="row" style="margin-top: 16rpx;">
          <view>聚合成本 ¥{{item.totalCost}}</view>
          <view>聚合市值 ¥{{item.totalMarketValue}}</view>
        </view>
        <view class="chips" wx:if="{{item.tags && item.tags.length}}">
          <view class="chip" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
        </view>
        <view class="list-item" wx:if="{{item.reviewId}}">
          <view class="muted">最近复盘 {{item.reviewDate}}</view>
          <view>{{item.reviewSummary}}</view>
        </view>
      </view>
    </block>
    <view class="empty" wx:else>暂无匹配的聚合持仓。</view>
  </view>

  <view class="section">
    <view class="section-title">历史资产</view>
    <block wx:if="{{assets.length}}">
      <view class="card" wx:for="{{assets}}" wx:key="id">
        <view class="row">
          <view class="strong">{{item.name}}</view>
          <view class="{{item.pnlClass}}">¥{{item.pnl}}</view>
        </view>
        <view class="muted">{{item.code || '未填代码'}} · {{item.date}}</view>
        <view class="row" style="margin-top: 16rpx;">
          <view>成本 ¥{{item.cost}}</view>
          <view>市值 ¥{{item.marketValue}}</view>
        </view>
        <view class="muted" wx:if="{{item.quoteMeta}}">{{item.quoteMeta}}</view>
        <view class="chips" wx:if="{{item.tags && item.tags.length}}">
          <view class="chip" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
        </view>
        <view class="actions">
          <view class="action-link" data-id="{{item.id}}" bindtap="startEdit">编辑</view>
          <view class="action-link danger" data-id="{{item.id}}" bindtap="deleteAsset">删除</view>
        </view>
      </view>
    </block>
    <view class="empty" wx:else>暂无匹配的资产记录。</view>
  </view>
</view>
