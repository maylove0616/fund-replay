<view class="page">
  <view class="hero">
    <view class="hero-title">我的</view>
    <view class="hero-subtitle">登录后只会读取和写入你自己的基金记录与复盘数据。</view>
  </view>

  <view class="section" wx:if="{{!loggedIn}}">
    <view class="form-card">
      <view class="section-title">账号登录</view>
      <view class="helper">点击登录后，会按你的微信身份隔离数据。其他用户无法看到你的记录。</view>
      <button class="button" bindtap="handleLogin">微信登录</button>
    </view>
  </view>

  <view class="section" wx:if="{{loggedIn}}">
    <view class="form-card">
      <view class="section-title">账号资料</view>
      <view class="profile-header">
        <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
          <image class="avatar" wx:if="{{draftAvatarUrl}}" src="{{draftAvatarUrl}}" mode="aspectFill" />
          <view class="avatar avatar-empty" wx:else>头像</view>
        </button>
        <view class="profile-meta">
          <view class="strong">{{profile.nickname || '微信用户'}}</view>
          <view class="muted">OpenID 已绑定当前账号</view>
        </view>
      </view>

      <view class="field">
        <text class="field-label">昵称</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="请输入昵称" value="{{draftNickname}}" bindinput="handleNicknameInput" />
      </view>

      <button class="button" bindtap="saveProfile">保存资料</button>
      <button class="button button-secondary" bindtap="handleLogout">退出登录</button>
    </view>
  </view>
</view>
